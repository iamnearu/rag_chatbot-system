# ═══════════════════════════════════════════════════════════════════
# OCR SERVICE CONFIGURATION - EXAMPLE
# Copy file này thành .env và điền giá trị thực tế
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=your_db_name
DATABASE_URL=postgresql+psycopg2://your_db_user:your_secure_password@localhost:5432/your_db_name

# ═══════════════════════════════════════════════════════════════════
# RABBITMQ CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
RABBIT_URL=amqp://guest:guest@localhost:5672/
# Queue nhận message từ Upload Service
RABBIT_QUEUE_UPLOADS=queue_uploads
# Queue gửi kết quả sau khi OCR hoàn thành
RABBIT_QUEUE_FINISHED=queue_finished
#
# ═══════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# ═══════════════════════════════════════════════════════════════════
# MINIO CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
# Bucket nhận file PDF từ Upload Service
MINIO_INPUT_BUCKET=document-uploads
# Bucket lưu kết quả OCR (md, json, images)
MINIO_OUTPUT_BUCKET=ocr-results

# ═══════════════════════════════════════════════════════════════════
# MODEL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
MODEL_PATH=/path/to/your/DeepSeek-OCR/model
TRITON_PTXAS_PATH=/usr/local/cuda-11.8/bin/ptxas

# ═══════════════════════════════════════════════════════════════════
# INPUT/OUTPUT PATHS (Local filesystem)
# ═══════════════════════════════════════════════════════════════════
OUTPUT_PATH=./outputs
UPLOAD_PATH=./uploads

# ═══════════════════════════════════════════════════════════════════
# API SETTINGS
# ═══════════════════════════════════════════════════════════════════
API_PORT=8001
API_HOST=0.0.0.0
MAX_UPLOAD_MB=200

# ═══════════════════════════════════════════════════════════════════
# PYTORCH CONFIGURATION
# ═══════════════════════════════════════════════════════════════════
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# ═══════════════════════════════════════════════════════════════════
# OCR ENGINE SELECTION
# ═══════════════════════════════════════════════════════════════════
# Options:
# - "auto":     Tự động (> 2MB: MinerU | < 2MB: Deepseek)
# - "deepseek": DeepSeek vLLM (chi tiết, GPU 6-8GB)
# - "mineru":   MinerU CLI (nhanh, GPU 2-3GB)
# - "docling":  Docling V2 (CPU-based, fallback)
OCR_ENGINE=auto

# ═══════════════════════════════════════════════════════════════════
# IMAGE PREPROCESSING
# ═══════════════════════════════════════════════════════════════════
# Bật/tắt chỉnh nghiêng ảnh (deskew) - true/false
DESKEW_ENABLED=true
# Số pixel crop mỗi cạnh để loại bỏ viền/margin (0 = không crop)
CROP_MARGIN_PIXELS=60