EMBEDDING_DIM=1024
EMBEDDING_MAX_TOKEN_SIZE=8192

# RAG Configuration
RAG_WORK_DIR="./rag_workspace"
PROMPTS_DIR="./prompts"
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=100
RAG_ENABLE_LLM_CACHE=True
RAG_MAX_ASYNC_JOBS=2

# Storage Configuration
STORAGE_TYPE="postgres"
ENABLE_GRAPH_STORAGE=True
GRAPH_STORAGE_TYPE="neo4j"

# OCR Service (Machine 156 → 10.0.0.156)
OCR_SERVICE_URL="http://10.0.0.156:8001"
