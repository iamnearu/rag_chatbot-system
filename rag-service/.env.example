# VLM Configuration (Machine 125 -> 10.0.0.125)
VLM_BASE_URL="http://10.0.0.125:11434/v1" 
VLM_API_KEY="ollama"
VLM_MODEL_NAME="qwen3-vl:8b-instruct-q8_0"

# Reranker Configuration (FlagEmbedding local, chạy trên máy này)
RERANKER_MODEL_NAME="BAAI/bge-reranker-v2-m3"
RERANKER_DEVICE="cuda"
RERANKER_ENABLED=True
RERANKER_TOP_N=3

# Embedding Service Configuration (Local - Machine "Toi")
EMBEDDING_SERVICE_URL="http://localhost:8003"
