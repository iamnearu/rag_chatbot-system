
# Server Configuration
PROJECT_NAME="EOVCopilot RAG Service"
API_V1_STR="/api/v1"
LOG_LEVEL="INFO"
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:8006", "*"]'
PORT=8006

# MinIO Configuration (Machine 156 -> 10.0.0.156)
MINIO_ENDPOINT="10.0.0.156:9000"
