NEO4J_PASSWORD="eovneoj4pw"

# LLM Configuration (Local - Machine "Toi")
LLM_BASE_URL="http://localhost:11434/v1"
LLM_API_KEY="ollama"
LLM_MODEL_NAME="qwen3:8b-q8_0"
